---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import PostHog from '../components/posthog.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  accent: string;
  accentRgb: string;
  page: 'home' | 'blog-index' | 'blog-post';
  ogType?: 'website' | 'article';
}
const { title, description, accent, accentRgb, page, ogType = 'website' } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;
const ogImageAlt =
  "The Layernetes layered-stack mark and wordmark on a dark terminal-style background, with the tagline 'Your agent is ready. Give it a URL.' and the command llnate push printing a live agent URL.";

// Shared Organization JSON-LD — who is behind Layernetes.
const orgJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Layernetes',
  url: 'https://layernetes.wtp.io',
  logo: 'https://layernetes.wtp.io/favicon.svg',
  sameAs: ['https://github.com/elg0nz/layernetes', 'https://sanscourier.ai', 'https://www.learninglayer.ai/'],
  parentOrganization: { '@type': 'Organization', name: 'Sanscourier.ai', url: 'https://sanscourier.ai' },
  description:
    'Layernetes is the Learning Layer cloud for AI agents, built by Sanscourier.ai. Write a CrewAI-powered agent, run llnate push, and it goes live at a public URL callable over MCP or HTTP.',
});

// Background geometry differs slightly per page in the source designs (glow
// size/position, grid/canvas mask ellipse) — everything else is shared.
const VARIANTS = {
  home: {
    glowTop: '-260px', glowWidth: '1100px', glowHeight: '780px', glowBlur: '30px', glowVar: 0.65,
    gridMask: 'radial-gradient(ellipse 80% 55% at 50% 0%, #000 30%, transparent 78%)',
    canvasMask: 'radial-gradient(ellipse 115% 70% at 50% 4%, #000 8%, transparent 66%)',
    canvasOpacity: 0.34,
    topFade: true,
  },
  'blog-index': {
    glowTop: '-280px', glowWidth: '1100px', glowHeight: '720px', glowBlur: '34px', glowVar: 0.7,
    gridMask: 'radial-gradient(ellipse 80% 45% at 50% 0%, #000 30%, transparent 78%)',
    canvasMask: 'radial-gradient(ellipse 115% 70% at 50% 4%, #000 8%, transparent 66%)',
    canvasOpacity: 0.34,
    topFade: false,
  },
  'blog-post': {
    glowTop: '-300px', glowWidth: '1000px', glowHeight: '640px', glowBlur: '36px', glowVar: 0.7,
    gridMask: 'radial-gradient(ellipse 70% 35% at 50% 0%, #000 30%, transparent 78%)',
    canvasMask: 'radial-gradient(ellipse 120% 60% at 50% 2%, #000 6%, transparent 60%)',
    canvasOpacity: 0.3,
    topFade: false,
  },
};
const v = VARIANTS[page];
const rootStyle = `--accent:${accent}; --accent-rgb:${accentRgb}; --glow:${v.glowVar};`;
const canvasStyle = `opacity:${v.canvasOpacity}; mask-image:${v.canvasMask}; -webkit-mask-image:${v.canvasMask};`;
const gridStyle = `mask-image:${v.gridMask}; -webkit-mask-image:${v.gridMask};`;
const glowStyle = `top:${v.glowTop}; width:${v.glowWidth}; height:${v.glowHeight}; filter: blur(${v.glowBlur});`;
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="author" content="Sanscourier.ai" />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <link rel="canonical" href={canonical} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Agent-readable doc discovery (llms.txt convention) -->
  <link rel="alternate" type="text/plain" title="llms.txt — agent quickstart" href="https://layernetes.wtp.io/llms.txt" />
  <link rel="alternate" type="text/plain" title="llms-full.txt — deep agent reference" href="https://layernetes.wtp.io/llms-full.txt" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content="Layernetes" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={ogImageAlt} />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={ogImageAlt} />
  <meta name="twitter:site" content="@sanscourier" />
  <meta name="twitter:creator" content="@sanscourier" />

  <script type="application/ld+json" set:html={orgJsonLd} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet" />
  <slot name="head" />
  <PostHog />
</head>
<body>
  <div class="ll-root" style={rootStyle}>
    <canvas id="bg-canvas" class="ll-canvas" aria-hidden="true" style={canvasStyle}></canvas>
    <div class="ll-grid" style={gridStyle}></div>
    <div class="ll-glow" style={glowStyle}></div>
    {v.topFade && <div class="ll-top-fade"></div>}

    <div class="ll-content">
      <Nav current={page} />
      <slot />
      <Footer current={page} />
    </div>
  </div>

  <script>
    import { initShaderBackground } from '../scripts/shader-bg.js';
    import { initCopyButtons } from '../scripts/copy.js';
    initShaderBackground('bg-canvas');
    initCopyButtons();
  </script>
</body>
</html>
