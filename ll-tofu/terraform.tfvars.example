# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# The API token is best supplied via the CLOUDFLARE_API_TOKEN env var instead.

cloudflare_account_id = "your-account-id"
zone_id               = "your-zone-id" # zone for learninglayer.ai

# platform_domain = "layernetes.learninglayer.ai"  # default
# tunnel_name     = "layernetes-shared"            # default

# ── Optional: gate Gitea signup behind GitHub (needs a Zero Trust GitHub IdP) ──
# github_identity_provider_id = "your-github-idp-id"
# github_organization         = "your-github-org"

# ── Optional: manage the Pages site here instead of via wrangler ──
# manage_pages  = true
# site_hostname = "layernetes.learninglayer.ai"
