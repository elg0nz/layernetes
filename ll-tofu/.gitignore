# OpenTofu / Terraform
.terraform/
.terraform.tfstate.lock.info

# State (local backend) — never commit
*.tfstate
*.tfstate.*

# Real variable values — commit only the .example
*.tfvars
!*.tfvars.example

# Crash / override
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# The dependency lock (.terraform.lock.hcl) IS committed — do not ignore it.
